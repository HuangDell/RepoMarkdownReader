{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "build:wasm": "NEXT_TELEMETRY_DISABLED=1 NEXT_TEST_WASM=1 next build --webpack",
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "dev:wasm": "NEXT_TELEMETRY_DISABLED=1 NEXT_TEST_WASM=1 next dev --webpack",
    "start": "next start",
    "types:check": "fumadocs-mdx && NEXT_TELEMETRY_DISABLED=1 next typegen && tsc --noEmit",
    "types:check:wasm": "fumadocs-mdx && NEXT_TELEMETRY_DISABLED=1 NEXT_TEST_WASM=1 next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.5",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9"
  }
}
